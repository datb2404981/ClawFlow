# Mặc định (dev) client gọi thẳng `http://127.0.0.1:8080/api/v1` (tránh lỗi tải file lớn qua proxy Vite).
# Bắt buộc nếu bạn cần URL API khác:
# VITE_API_URL=http://localhost:8080/api/v1
#
# Bật lại gọi qua Vite proxy (`/api/v1` cùng origin), ví dụ khi 8080 bị chặn:
# VITE_DEV_API_PROXY=1
# Cổng Nest nếu không phải 8080 (khi KHÔNG dùng VITE_DEV_API_PROXY):
# VITE_NEST_PORT=8080
#
# Dev trên host (ngoài Docker):
VITE_BACKEND_HOST=
VITE_BACKEND_PORT=8080
#
# Dev trong Docker Compose: thường set VITE_BACKEND_HOST=backend (tên service).
