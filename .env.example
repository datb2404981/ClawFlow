# Sao chép thành `.env` tại thư mục gốc ClawFlow:  cp .env.example .env
# File `.env` không được commit (đã có trong .gitignore).
#
# Docker Compose: `backend` / `ai_core` nạp MONGO_URI từ Backend/.env (env_file) — đặt Atlas ở đó.
# File `.env` gốc repo (file này) chủ yếu cho ${JWT_SECRET} khi compose; có thể bỏ trống MONGO_URI ở đây.
# Mongo trong Docker: docker compose --profile local-db up -d mongodb rồi trong Backend/.env dùng
# MONGO_URI=mongodb://mongodb:27017/clawflow

# --- Backend/.env (Nest + Docker backend) — bắt buộc có MONGO_URI thật ---
# PORT=8080
# MONGO_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/DATABASE?retryWrites=true&w=majority
# Sau Google OAuth, backend redirect về đây — trùng chính xác URL bạn mở Vite (localhost vs 127.0.0.1, cổng).
# FRONTEND_URL=http://localhost:5173

# --- Tùy chọn: biến gốc cho compose (override JWT nếu cần) ---
PORT=8080
MONGO_URI=
# Bắt buộc khi chạy backend (Compose có giá trị mặc định nếu không set).
JWT_SECRET=thay-bang-chuoi-dai-ngau-nhien-khong-dung-commit
# Hoặc: JWT_ACCESS_SECRET=...

# --- Google OAuth (tùy chọn) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# OAuth callback phải là API Nest (8080), không dùng 8000 (AI_Core).
# GOOGLE_CALLBACK_URL=http://localhost:8080/api/v1/auth/google/callback

# --- AI_Core ---
# PORT=8000
# URL gốc AI Core (FastAPI), không có dấu /. Backend gọi POST /api/v1/refine-system-prompt
# AI_CORE_BASE_URL=http://127.0.0.1:8000

# --- Frontend (Vite) ---
# URL đầy đủ tới API (khuyến nghị):
# VITE_API_URL=http://localhost:8080/api/v1
# Hoặc chỉ origin — axios sẽ thêm /api/v1:
# VITE_API_BASE_URL=http://localhost:8080
