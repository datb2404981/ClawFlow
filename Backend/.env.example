# Copy thành `.env` và điền giá trị. Không commit `.env`.
#
# Giới hạn body JSON/URL (ví dụ logo workspace dạng base64). Mặc định 2mb nếu không gán.
# HTTP_JSON_LIMIT=2mb
#
# Bảo vệ API admin seed (`/api/v1/admin/seed/*` trừ `GET .../ping`):
# — Đặt chuỗi ngẫu nhiên mạnh; gửi cùng giá trị qua header `X-Admin-Seed-Key` hoặc `Authorization: Bearer <key>`.
# — Nếu bỏ trống, server trả 503 "Chưa cấu hình ADMIN_SEED_KEY".
ADMIN_SEED_KEY= ClawFlowAdminSeedKey
