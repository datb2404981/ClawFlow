# Copy thành `.env` và điền giá trị. Không commit `.env`.
#
# Cloudflare R2 (S3 API) — knowledge base. Account ID: Cloudflare dashboard → R2.
# Endpoint: https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com, region: auto.
# Nếu thiếu bất kỳ biến nào dưới, upload knowledge trả 503; app vẫn khởi động.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=clawflow-knowledge
#
# Google AI — embedding knowledge (Generative Language API, cùng khoá với Google AI Studio).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model: Google AI Studio — dùng gemini-embedding-001 (embedContent). text-embedding-004 thường 404 trên API này.
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Chỉ đổi khi dùng model khác số chiều (phải trùng GEMINI_EMBEDDING_DIMENSION + index Atlas)
# GEMINI_EMBEDDING_DIMENSION=768
# Tối đa từ mỗi câu gửi embed (cắt thêm nếu chunk theo ký tự mà dài theo từ)
# GEMINI_EMBEDDING_MAX_WORDS=5000
#
# Cắt chunk (ký tự) cho RAG
# CHUNK_MAX_CHARS=1200
# CHUNK_OVERLAP=150
#
# PDF knowledge: nếu text layer rỗng (scan), bật OCR (Tesseract + @napi-rs/canvas).
# KNOWLEDGE_PDF_OCR=1
# Ocr tối đa N trang / tệp (mặc định 10)
# KNOWLEDGE_PDF_OCR_MAX_PAGES=10
# Ngôn ngữ Tesseract (mặc định tiếng Việt + Anh)
# KNOWLEDGE_PDF_OCR_LANGS=vie+eng
# Tắt hẳn OCR (chỉ pdf-parse + PDF.js text layer):
# KNOWLEDGE_PDF_OCR=0
#
# Giới hạn body JSON / urlencoded (mặc định 100mb, trùng tầm upload knowledge).
# HTTP_BODY_LIMIT=100mb
# (Tùy chọn) Tên cũ: HTTP_JSON_LIMIT
#
# Nếu vẫn 413 dù tệp <100MB: thường do Nginx/hosting (vd. Nginx: client_max_body_size 100M;).
#

