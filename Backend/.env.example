# Copy thành `.env` và điền giá trị. Không commit `.env`.
#
# Redis — BullMQ (hàng đợi task). Chạy local: redis-server hoặc `docker compose up -d redis`.
# Docker Compose backend đã ghi đè REDIS_URI=redis://redis:6379; local mặc định Nest dùng redis://127.0.0.1:6379.
# REDIS_URI=redis://127.0.0.1:6379
#
# Cloudflare R2 (S3 API) — knowledge base. Account ID: Cloudflare dashboard → R2.
# Endpoint: https://${R2_ACCOUNT_ID}.r2.cloudflarestorage.com, region: auto.
# Nếu thiếu bất kỳ biến nào dưới, upload knowledge trả 503; app vẫn khởi động.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=clawflow-knowledge
#
# Google AI — embedding knowledge (Generative Language API, cùng khoá với Google AI Studio).
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Model: Google AI Studio — dùng gemini-embedding-001 (embedContent). text-embedding-004 thường 404 trên API này.
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# Chỉ đổi khi dùng model khác số chiều (phải trùng GEMINI_EMBEDDING_DIMENSION + index Atlas)
# GEMINI_EMBEDDING_DIMENSION=768
# Tối đa từ mỗi câu gửi embed (cắt thêm nếu chunk theo ký tự mà dài theo từ)
# GEMINI_EMBEDDING_MAX_WORDS=5000
#
# Cắt chunk (ký tự) cho RAG
# CHUNK_MAX_CHARS=1200
# CHUNK_OVERLAP=150
#
# PDF knowledge: nếu text layer rỗng (scan), bật OCR (Tesseract + @napi-rs/canvas).
# KNOWLEDGE_PDF_OCR=1
# Ocr tối đa N trang / tệp (mặc định 10)
# KNOWLEDGE_PDF_OCR_MAX_PAGES=10
# Ngôn ngữ Tesseract (mặc định tiếng Việt + Anh)
# KNOWLEDGE_PDF_OCR_LANGS=vie+eng
# Tắt hẳn OCR (chỉ pdf-parse + PDF.js text layer):
# KNOWLEDGE_PDF_OCR=0
#
# Giới hạn body JSON / urlencoded (mặc định 100mb, trùng tầm upload knowledge).
# HTTP_BODY_LIMIT=100mb
# (Tùy chọn) Tên cũ: HTTP_JSON_LIMIT
#
# Nếu vẫn 413 dù tệp <100MB: thường do Nginx/hosting (vd. Nginx: client_max_body_size 100M;).
#
# --- Ollama (service `ai_core` trong Docker nạp cùng file Backend/.env) ---
# Tên model phải trùng `ollama list` trên máy host (vd. qwen2.5:7b, llama3.1:8b, llama3.2:latest).
# OLLAMA_MODEL=llama3.2:latest
# Trên Docker Desktop (Mac/Windows), AI_Core gọi Ollama trên host:
# OLLAMA_BASE_URL=http://host.docker.internal:11434
#
# --- LangSmith (AI_Core đọc cùng Backend/.env trong Docker) ---
# https://smith.langchain.com/settings → API Keys
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_pt_...
# (tuỳ chọn) LANGSMITH_PROJECT=clawflow
# Tương thích tên cũ: LANGCHAIN_TRACING_V2=true, LANGCHAIN_API_KEY=...
# Không để dòng LANGSMITH_API_KEY= rỗng — Docker coi là đã set và sẽ không đọc key từ AI_Core/.env.
# EU workspace — đặt cùng một URL cho cả hai (SDK dùng LANGCHAIN_ENDPOINT khi gửi trace):
# LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
# LANGCHAIN_ENDPOINT=https://eu.api.smith.langchain.com
# Kiểm tra sau khi chạy AI_Core: GET http://localhost:8000/ → `langsmith.endpoint`, `langsmith.workspace_id_configured`
# Nếu ingest EU vẫn 403: xóa LANGSMITH_WORKSPACE_ID nếu không chắc (chỉ dùng UUID workspace trong Settings);
# tạo PAT mới trên eu.smith; key không có dấu ngoặc / xuống dòng.
#
# --- Atlas Vector Search (RAG task) ---
# Tên index $vectorSearch trên collection `knowledge_chunks` (trùng Atlas Search index).
# MONGODB_VECTOR_INDEX_NAME=default
#
# RAG hybrid: cùng lúc $vectorSearch (Atlas) + MongoDB `$text` trên `chunk_text`, gộp trong backend.
# Cần text index (schema `KnowledgeChunk` — chạy syncIndexes / khởi động app để tạo). Tắt: RAG_HYBRID_TEXT=0
# RAG_HYBRID_TEXT=1
# Tối đa chunk sau khi gộp vector+text (mặc định 6)
# RAG_MERGED_MAX_CHUNKS=6

